# ── App ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
API_BASE_URL=http://localhost:3001
WEB_BASE_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# ── Database ─────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/jethro_academy?schema=public"

# ── JWT ──────────────────────────────────────────────────────────────
JWT_SECRET="minimum-32-character-secret-here!!"
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET="another-minimum-32-character-secret!!"
JWT_REFRESH_EXPIRES_IN=30d
BCRYPT_SALT_ROUNDS=12

# ── Stripe ───────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CURRENCY=usd

# ── AWS S3 ────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_S3_BUCKET=jethro-uploads
AWS_S3_PRESIGNED_URL_EXPIRES=3600

# ── Vimeo ─────────────────────────────────────────────────────────────
VIMEO_ACCESS_TOKEN=...
VIMEO_CLIENT_ID=...
VIMEO_CLIENT_SECRET=...

# ── Email / SMTP ──────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM_NAME=Jethro Academy
EMAIL_FROM_ADDRESS=noreply@yourdomain.com

# ── Rate Limiting ─────────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100
